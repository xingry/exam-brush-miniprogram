page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 打卡卡片 */
.checkin-card {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.checkin-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.month-title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.checkin-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
  display: block;
}

.streak-section {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
}

.streak-item {
  flex: 1;
  text-align: center;
}

.streak-number {
  font-size: 56rpx;
  font-weight: bold;
  display: block;
}

.streak-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.checkin-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #4A90D9;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 20rpx;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn.checked {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
}

.checkin-btn[disabled] {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.6);
}

.checkin-tip {
  text-align: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 日历卡片 */
.calendar-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.legend {
  display: flex;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.legend-dot.checked {
  background: #4A90D9;
}

.legend-dot.today {
  background: #FF9500;
}

.legend-dot.normal {
  background: #f0f0f0;
}

.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.week-day {
  font-size: 26rpx;
  color: #999;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  padding: 20rpx 0;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  position: relative;
  background: #f9f9f9;
}

.day-cell.other-month {
  opacity: 0.3;
}

.day-cell.today {
  background: #FFF3E0;
  border: 2rpx solid #FF9500;
}

.day-cell.checked {
  background: #4A90D9;
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.day-cell.today .day-number {
  color: #FF9500;
  font-weight: bold;
}

.day-cell.checked .day-number {
  color: #fff;
}

.check-mark {
  position: absolute;
  bottom: 4rpx;
  font-size: 16rpx;
  color: #fff;
}

/* 规则卡片 */
.rules-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.rules-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rule-dot {
  width: 36rpx;
  height: 36rpx;
  background: #E3F2FD;
  color: #4A90D9;
  font-size: 22rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rule-text {
  font-size: 28rpx;
  color: #666;
}

/* 徽章卡片 */
.badges-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.badges-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.badges-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  background: #f9f9f9;
  opacity: 0.5;
}

.badge-item.unlocked {
  opacity: 1;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.badge-icon {
  font-size: 48rpx;
}

.badge-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.badge-desc {
  font-size: 20rpx;
  color: #999;
}
