page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.word-count {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

/* 反馈类型 */
.type-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 10rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-item.active {
  background: #E3F2FD;
  border-color: #4A90D9;
}

.type-icon {
  font-size: 40rpx;
}

.type-text {
  font-size: 24rpx;
  color: #666;
}

.type-item.active .type-text {
  color: #4A90D9;
  font-weight: 500;
}

/* 内容输入 */
.content-input {
  width: 100%;
  height: 240rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.contact-input {
  width: 100%;
  height: 88rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 提示 */
.tips {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #FFF8E1;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #F57C00;
  line-height: 1.5;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 40rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
}

/* FAQ */
.faq-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.faq-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.faq-arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.faq-arrow.open {
  transform: rotate(180deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.faq-answer.show {
  max-height: 200rpx;
}

.faq-answer text {
  display: block;
  padding: 0 24rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
