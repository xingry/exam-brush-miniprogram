<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="avatar" wx:if="{{avatarUrl}}">
      <image class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
    </view>
    <view class="avatar" wx:else>
      <text class="avatar-placeholder">{{nickName ? nickName[0] : '同'}}</text>
    </view>
    <view class="user-info">
      <text class="nick-name">{{nickName || '同学'}}</text>
      <text class="user-id">ID: {{openid || '未登录'}}</text>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-section">
    <view class="section-title">📊 学习统计</view>
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">📚</text>
        <text class="stat-number">{{totalQuestions}}</text>
        <text class="stat-label">累计刷题</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">✅</text>
        <text class="stat-number">{{correctRate}}%</text>
        <text class="stat-label">正确率</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🔥</text>
        <text class="stat-number">{{streakDays}}</text>
        <text class="stat-label">连续打卡</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📝</text>
        <text class="stat-number">{{totalMistakes}}</text>
        <text class="stat-label">错题总数</text>
      </view>
    </view>
  </view>

  <!-- 学习趋势 -->
  <view class="trend-section">
    <view class="section-title">📈 学习趋势</view>
    <view class="trend-card">
      <view class="trend-bar" wx:for="{{weekData}}" wx:key="day">
        <view class="trend-day">{{day}}</view>
        <view class="trend-chart">
          <view class="trend-fill" style="height: {{height}}rpx"></view>
        </view>
        <view class="trend-count">{{count}}题</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="section-title">⚙️ 设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="shareApp">
        <text class="menu-icon">📤</text>
        <text class="menu-text">分享给好友</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="feedback">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="about">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">版本 1.0.0</text>
    <text class="version-text">© 2026 大圣工作室</text>
  </view>
</view>
