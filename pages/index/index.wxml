<view class="container">
  <!-- 顶部问候 -->
  <view class="card greeting">
    <text class="greeting-title">你好，{{nickName || '同学'}}</text>
    <text class="greeting-subtitle">今天也要加油刷题哦！💪</text>
  </view>

  <!-- 今日任务 -->
  <view class="card task-card">
    <view class="task-header">
      <text class="task-title">📚 今日任务</text>
      <text class="task-date">{{today}}</text>
    </view>
    <view class="task-progress">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
      <text class="progress-text">{{finishedCount}} / {{targetCount}} 题</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="card">
    <view class="section-title">快捷入口</view>
    <view class="menu-grid">
      <view class="menu-item" bindtap="goToPractice">
        <view class="menu-icon">✍️</view>
        <text class="menu-text">开始刷题</text>
      </view>
      <view class="menu-item" bindtap="goToMistakes">
        <view class="menu-icon">📝</view>
        <text class="menu-text">错题本</text>
      </view>
      <view class="menu-item" bindtap="goToDailyCheck">
        <view class="menu-icon">📅</view>
        <text class="menu-text">每日打卡</text>
      </view>
      <view class="menu-item" bindtap="goToProfile">
        <view class="menu-icon">👤</view>
        <text class="menu-text">我的</text>
      </view>
    </view>
  </view>

  <!-- 推荐练习 -->
  <view class="card">
    <view class="section-title">🔥 热门推荐</view>
    <view class="recommend-list">
      <view class="recommend-item" bindtap="goToPractice" data-type="network">
        <view class="recommend-info">
          <text class="recommend-title">计算机网络基础</text>
          <text class="recommend-count">500 题</text>
        </view>
        <text class="recommend-tag">必刷</text>
      </view>
      <view class="recommend-item" bindtap="goToPractice" data-type="database">
        <view class="recommend-info">
          <text class="recommend-title">数据库原理</text>
          <text class="recommend-count">380 题</text>
        </view>
        <text class="recommend-tag">热门</text>
      </view>
      <view class="recommend-item" bindtap="goToPractice" data-type="security">
        <view class="recommend-info">
          <text class="recommend-title">网络安全基础</text>
          <text class="recommend-count">420 题</text>
        </view>
        <text class="recommend-tag">新题</text>
      </view>
    </view>
  </view>
</view>
