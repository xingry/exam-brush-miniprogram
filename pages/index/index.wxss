page {
  background: linear-gradient(180deg, #4A90D9 0%, #f5f5f5 300rpx);
}

.greeting {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.greeting-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.greeting-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.login-btn {
  margin-top: 20rpx;
  background: #fff !important;
  color: #4A90D9 !important;
  font-weight: 600;
  border-radius: 30rpx;
  padding: 12rpx 32rpx;
  font-size: 28rpx;
}

.task-card {
  background: #fff !important;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.task-date {
  font-size: 26rpx;
  color: #999;
}

.task-progress {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9 0%, #67C23A 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
  min-width: 120rpx;
  text-align: right;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
}

.menu-icon {
  font-size: 48rpx;
}

.menu-text {
  font-size: 24rpx;
  color: #666;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommend-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.recommend-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recommend-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.recommend-count {
  font-size: 24rpx;
  color: #999;
}

.recommend-tag {
  font-size: 22rpx;
  color: #fff;
  background: #4A90D9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
