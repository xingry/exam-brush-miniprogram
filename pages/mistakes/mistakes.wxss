page {
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.container {
  padding: 20rpx;
}

.stats-card {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stats-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.filter-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.filter-item {
  padding: 12rpx 28rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.filter-item.active {
  background: #4A90D9;
  color: #fff;
}

.mistakes-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mistake-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.mistake-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.mistake-type {
  font-size: 24rpx;
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.mistake-date {
  font-size: 24rpx;
  color: #999;
}

.mistake-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.mistake-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mistake-count {
  font-size: 24rpx;
  color: #F56C6C;
}

.mistake-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #4A90D9;
}

.action-btn.delete {
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.bottom-review {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-review {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}
