<view class="container">
  <!-- 题目进度 -->
  <view class="progress-header">
    <text class="progress-text">{{current + 1}} / {{total}}</text>
    <view class="progress-dots">
      <view class="dot {{index <= current ? 'active' : ''}}" wx:for="{{5}}" wx:key="*this"></view>
    </view>
  </view>

  <!-- 题目卡片 -->
  <view class="question-card">
    <view class="question-type">{{questionType}}</view>
    <view class="question-content">{{currentQuestion.question}}</view>
  </view>

  <!-- 选项列表 -->
  <view class="options-list">
    <view 
      class="option-item {{selected === index ? 'selected' : ''}} {{showAnswer && index === correctIndex ? 'correct' : ''}} {{showAnswer && selected === index && selected !== correctIndex ? 'wrong' : ''}}"
      wx:for="{{currentQuestion.options}}" 
      wx:key="*this"
      bindtap="selectOption"
      data-index="{{index}}"
    >
      <text class="option-letter">{{['A', 'B', 'C', 'D'][index]}}</text>
      <text class="option-text">{{item}}</text>
    </view>
  </view>

  <!-- 答案区域 -->
  <view class="answer-section" wx:if="{{showAnswer}}">
    <view class="answer-result {{isCorrect ? 'correct' : 'wrong'}}">
      <text class="result-icon">{{isCorrect ? '✅' : '❌'}}</text>
      <text class="result-text">{{isCorrect ? '回答正确' : '回答错误'}}</text>
    </view>
    
    <view class="explanation">
      <text class="explanation-title">📖 答案解析</text>
      <text class="explanation-content">{{currentQuestion.explanation}}</text>
    </view>

    <view class="action-buttons">
      <button class="btn-secondary" bindtap="collectMistake" wx:if="{{!isCorrect}}">
        收藏错题
      </button>
      <button class="btn-primary" bindtap="nextQuestion">
        {{current < total - 1 ? '下一题' : '完成练习'}}
      </button>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar" wx:else>
    <button class="btn-submit" bindtap="submitAnswer" disabled="{{selected === -1}}">
      提交答案
    </button>
  </view>
</view>
