page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.progress-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.dot.active {
  background: #4A90D9;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.question-type {
  font-size: 24rpx;
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 24rpx;
}

.question-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
  font-weight: 500;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  transition: all 0.2s ease;
}

.option-item.selected {
  border-color: #4A90D9;
  background: rgba(74, 144, 217, 0.05);
}

.option-item.correct {
  border-color: #67C23A;
  background: rgba(103, 194, 58, 0.1);
}

.option-item.wrong {
  border-color: #F56C6C;
  background: rgba(245, 108, 108, 0.1);
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  flex-shrink: 0;
}

.option-item.selected .option-letter {
  background: #4A90D9;
  color: #fff;
}

.option-item.correct .option-letter {
  background: #67C23A;
  color: #fff;
}

.option-item.wrong .option-letter {
  background: #F56C6C;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  padding-top: 8rpx;
}

.answer-section {
  margin-top: 30rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.answer-result {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.answer-result.correct {
  background: rgba(103, 194, 58, 0.1);
}

.answer-result.wrong {
  background: rgba(245, 108, 108, 0.1);
}

.result-icon {
  font-size: 40rpx;
}

.result-text {
  font-size: 32rpx;
  font-weight: 600;
}

.answer-result.correct .result-text {
  color: #67C23A;
}

.answer-result.wrong .result-text {
  color: #F56C6C;
}

.explanation {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.explanation-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.explanation-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  background: #fff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.btn-primary {
  flex: 2;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-submit {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-submit[disabled] {
  background: #e0e0e0;
  color: #999;
}
